# Guardian service config (copy to .env). Uses ISOLATED demo data only.
PORT=8090
ACME_REPO_PATH=../acme-commerce

# Shared secret required on every request (set the same value in the UiPath
# Agent Builder tool). Leave blank to disable auth for local testing.
GUARDIAN_TOKEN=demo-guardian-secret

# Optional Neo4j mirror for the graph visual. Omit to run in-memory only.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=guardian-demo
